# ForgeKit .gitignore

# Cargo
/target
**/*.rs.bk
*.pdb
Cargo.lock

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Forge database
.forge/
# machine-local agent config (LLM endpoint etc.) — do not commit
.forge.toml
*.db
*.db-shm
*.db-wal
*.v3

# Test data
tests/fixtures/temp/
tests/fixtures/output/

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Internal planning documents (not for public repo)
/.planning/
STATE.md
PUBLISH.md
SPLICE_INTEGRATION.md
# internal design specs generated during development
docs/superpowers/

# CI/CD
/.ci/
/.travis.yml
/.gitlab-ci.yml
/azure-pipelines.yml
/appveyor.yml

# Agent/tooling files — not user-facing, keep out of public repo
CLAUDE.md
AGENTS.md
GEMINI.md
.mcp.json
.mcp/
.magellan/
.hermes/
.claude/
.remember/
